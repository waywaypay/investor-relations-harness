{
  "ServiceName": "attest",
  "SourceConfiguration": {
    "AuthenticationConfiguration": {
      "AccessRoleArn": "arn:aws:iam::<ACCOUNT_ID>:role/attest-apprunner-access-role"
    },
    "AutoDeploymentsEnabled": true,
    "ImageRepository": {
      "ImageIdentifier": "<ACCOUNT_ID>.dkr.ecr.<REGION>.amazonaws.com/attest:latest",
      "ImageRepositoryType": "ECR",
      "ImageConfiguration": {
        "Port": "8000",
        "RuntimeEnvironmentVariables": {
          "LOG_LEVEL": "info",
          "ATTEST_EDGAR": "on",
          "ATTEST_EDGAR_USER_AGENT": "Attest disclosure-verification (contact: ir-ops@attest.example)"
        },
        "RuntimeEnvironmentSecrets": {
          "DATABASE_URL": "arn:aws:secretsmanager:<REGION>:<ACCOUNT_ID>:secret:attest/database-url",
          "ANTHROPIC_API_KEY": "arn:aws:ssm:<REGION>:<ACCOUNT_ID>:parameter/attest/anthropic-api-key"
        }
      }
    }
  },
  "InstanceConfiguration": {
    "Cpu": "512",
    "Memory": "1024",
    "InstanceRoleArn": "arn:aws:iam::<ACCOUNT_ID>:role/attest-apprunner-instance-role"
  },
  "HealthCheckConfiguration": {
    "Protocol": "HTTP",
    "Path": "/health",
    "Interval": 10,
    "Timeout": 5,
    "HealthyThreshold": 1,
    "UnhealthyThreshold": 5
  }
}
