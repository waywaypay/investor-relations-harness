{
  "name": "rule_findings",
  "description": "Labeled documents -> the deterministic rule findings they should (and should not) raise, scored against the Meridian Q1 FY2026 fixture. 'should_flag' is the compliance ground truth: a missed flag is catastrophic, so rule recall must be 1.0. 'should_not_flag' is the trust ground truth: a spurious flag erodes trust, so rule precision must be 1.0 on the curated set. Documents are run through verify_close_pack so both per-document and cross-document rules are exercised.",
  "filing_fixture": "meridian_q1_fy2026",
  "tenant": "meridian",
  "cases": [
    {
      "id": "reg_g_missing_equal_prominence",
      "documents": [
        {"id": "d", "kind": "release", "entity": "MRDN", "period": "FY2026-Q1",
         "text": "Non-GAAP diluted EPS of $1.12 was a record for the quarter.",
         "claims": [{"metric": "non_gaap_diluted_eps", "text": "$1.12"}]}
      ],
      "should_flag": ["reg_g.equal_prominence"],
      "should_not_flag": ["forward_looking.safe_harbor_required", "units.unit_mismatch",
                          "consistency.cross_document_mismatch"]
    },
    {
